---
// src/components/SectionPlayList.astro
import { Image } from "astro:assets";
import florDisco from "../assets/images/flor-disco.png";
import disco from "../assets/images/disco.png";
import ramaAbajo from "../assets/images/rama-arriba.png";
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full max-w-[1000px] mx-auto flex flex-col items-center text-center px-4 pt-20 mb-12" id="playlist">
  <h2 class="reveal-heading font-['Amoresa'] text-[#1a1a1a] mb-4" style="font-size: clamp(2.4rem, 10vw, 4rem);">
    {t.playlist.titulo}
  </h2>
  <p class="font-['WeddingSerif'] text-[#444] mb-6 max-w-[280px]" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">
    {t.playlist.subtitulo}
  </p>

  <div class="relative w-full max-w-[340px] mx-auto mb-8">
    <div class="flex items-center justify-center" style="padding-top: 50px;">
      <div class="flex flex-col justify-end items-start h-[33vh] relative z-20 rounded-[20px] px-6 pt-10 pb-6 text-left flex-shrink-0" style="background-color: #e8dcc8; width: 230px;">
        <p class="font-['WeddingSerif'] text-[#333] leading-relaxed mb-5" style="font-size: clamp(0.8rem, 2.8vw, 0.95rem);">
          {t.playlist.descripcion}
        </p>
        <a href="#" class="inline-block px-5 py-2 rounded-full font-['WeddingSerif'] tracking-widest text-white bg-[#1a1a1a] hover:bg-[#333] transition-colors" style="font-size: clamp(0.65rem, 2.2vw, 0.8rem);">
          {t.playlist.boton}
        </a>
      </div>
      <div class="flex-shrink-0 disco-container md:ml-[-18px] ml-[-12px] z-10" style="width: clamp(100px, 28vw, 130px);">
        <Image src={disco} alt="Disco" class="w-full h-[30vh] object-contain" widths={[140, 280]} />
      </div>
    </div>
    <div class="absolute z-30 pointer-events-none" style="top: -10px; left: -10px; width: 260px;">
      <Image src={florDisco} alt="" class="w-full h-auto" widths={[260, 520]} />
    </div>
  </div>

  <div class="w-full max-w-[300px] mx-auto mt-2">
    <Image src={ramaAbajo} alt="" class="reveal-heading w-full h-auto" widths={[280, 560]} />
  </div>
</div>

<style>
  .disco-container { animation: none; }
  .disco-container.animate { animation: discoSlide 4s cubic-bezier(0.45, 0, 0.55, 1) forwards; }
  @keyframes discoSlide {
    0%   { transform: translateX(-80%); }
    35%  { transform: translateX(0%); }
    65%  { transform: translateX(0%); }
    100% { transform: translateX(0%); }
  }
</style>

<script>
  const disco = document.querySelector('.disco-container');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        disco?.classList.add('animate');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  if (disco) observer.observe(disco);
</script>