---
import { Image } from "astro:assets";
import floralDividerTop from "../assets/images/floral-divider.png";
import casa from "../assets/images/casa.png";
import anillo from "../assets/images/anillo.png";
import florIzq from "../assets/images/flor-izq.png";
import florDer from "../assets/images/flor-der.png";
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full max-w-full mx-auto flex flex-col items-center text-center px-4 mt-6 mb-16">
  <div class="w-full max-w-[380px] mx-auto mb-0">
    <Image src={floralDividerTop} alt="" class="w-full h-auto" widths={[300, 600]} />
  </div>

  <div class="relative w-full flex items-start justify-center" style="min-height: 120px;">
    <div class="absolute z-10" style="left: clamp(-20px, -2vw, 0px); top: 30vh; width: clamp(70px, 18vw, 130px);">
      <Image src={florIzq} alt="" class="w-full h-auto" />
    </div>
    <div class="relative z-20 flex items-center justify-center pt-2">
      <h2 class="font-['Amoresa'] text-[#1a1a1a] leading-tight" style="font-size: clamp(2.4rem, 10vw, 4rem);">
        {t.prewedding.titulo}
      </h2>
    </div>
    <div class="absolute z-10" style="right: clamp(-20px, -2vw, 0px); top: 60vh; width: clamp(70px, 18vw, 130px);">
      <Image src={florDer} alt="" class="w-full h-auto" />
    </div>
  </div>

  <div class="mt-[-2%] mb-4">
    <Image src={casa} alt="Casa Pura Rooftop" class="w-auto h-auto max-w-[200px] md:max-w-[260px]" />
  </div>

  <p class="font-['WeddingSerif'] tracking-[.2em] text-black mb-3" style="font-size: clamp(1rem, 4vw, 1.4rem);">{t.prewedding.lugar}</p>
  <p class="font-['WeddingSerif'] tracking-[.2em] text-[#333] mb-1" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.fecha}</p>
  <p class="font-['WeddingSerif'] tracking-[.2em] text-[#333] mb-6" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.hora}</p>
  <p class="font-['WeddingSerif'] tracking-[.2em] uppercase text-black mb-1" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.dresscode_titulo}</p>
  <p class="font-['WeddingSerif'] tracking-[.2em] text-[#333] mb-4" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.dresscode_valor}</p>

  <div class="mb-8">
    <a href="#" class="inline-block px-8 py-2 border border-[#999] rounded-full font-['WeddingSerif'] tracking-widest text-[#666] hover:bg-[#f5f5f5] transition-colors" style="font-size: clamp(0.7rem, 2.5vw, 0.85rem);">
      {t.prewedding.ver_referencia}
    </a>
  </div>

  <div class="mb-4">
    <Image src={anillo} alt="anillo" class="w-auto h-auto max-w-[160px] md:max-w-[200px]" />
  </div>

  <h2 class="font-['Amoresa'] text-[#1a1a1a] mb-4" style="font-size: clamp(2.4rem, 10vw, 4rem);">{t.prewedding.celebracion}</h2>
  <p class="font-['WeddingSerif'] tracking-[.2em] text-[#333]" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.celebracion_fecha}</p>
</div>