---
// src/components/SectionPreWeding.astro
import { Image } from "astro:assets";
import floralDividerTop from "../assets/images/floral-divider.png";
import casa from "../assets/images/casa.png";
import anillo from "../assets/images/anillo.png";
import florIzq from "../assets/images/flor-izq.png";
import florDer from "../assets/images/flor-der.png";
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full max-w-[1000px] mx-auto flex flex-col items-center text-center px-4 mt-6 mb-16" id="eventos">
  <div class="w-full max-w-[380px] mx-auto mb-0">
    <Image id="floral-divider"  src={floralDividerTop} alt="" class="w-full h-auto" widths={[300, 600]} />
  </div>

  <div class="relative w-full flex items-start justify-center" style="min-height: 120px;">
    <div class="absolute z-10" style="left: clamp(-20px, -2vw, 0px); top: 30vh; width: clamp(70px, 18vw, 130px);">
      <Image id="flor-izq" src={florIzq} alt="" class="w-[380px] max-w-[180px] h-auto" />
    </div>
    <div class="relative z-20 flex items-center justify-center pt-2">
      <h2 class="reveal-heading font-['Amoresa'] text-[#1a1a1a] leading-tight" style="font-size: clamp(2.4rem, 10vw, 4rem);">
        {t.prewedding.titulo}
      </h2>
    </div>
    <div class="absolute z-10" style="right: clamp(-20px, -2vw, 0px); top: 60vh; width: clamp(70px, 18vw, 130px);">
      <Image id="flor-der" src={florDer} alt="" class="w-[380px] max-w-[180px] h-auto" />
    </div>
  </div>

  <div class="mt-[-2%] mb-4">
    <Image src={casa} alt="Casa Pura Rooftop" class="w-auto h-auto max-w-[200px] md:max-w-[260px]" />
  </div>

  <p class="font-['WeddingSerif'] tracking-[.2em] text-black mb-3" style="font-size: clamp(1rem, 4vw, 1.4rem);">{t.prewedding.lugar}</p>
  <p class="font-['WeddingSerif'] tracking-[.2em] text-[#333] mb-1" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.fecha}</p>
  <p class="font-['WeddingSerif'] tracking-[.2em] text-[#333] mb-6" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.hora}</p>
  <p class="font-['WeddingSerif'] tracking-[.2em] uppercase text-black mb-1" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.dresscode_titulo}</p>
  <p class="font-['WeddingSerif'] tracking-[.2em] text-[#333] mb-4" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.dresscode_valor}</p>

  <div class="mb-8">
    <a href="#" class="inline-block px-8 py-1 border border-[#999] rounded-full font-['WeddingSerif'] tracking-widest text-[#666] hover:bg-[#000] hover:text-white transition-colors" style="font-size: clamp(0.7rem, 2.5vw, 0.85rem);">
      {t.prewedding.ver_referencia}
    </a>
  </div>

  <div class="mb-4">
    <Image id="anillo" src={anillo} alt="anillo" class="w-auto h-auto max-w-[160px] md:max-w-[200px]" />
  </div>

  <h2 class="reveal-heading font-['Amoresa'] text-[#1a1a1a] mb-4" style="font-size: clamp(2.4rem, 10vw, 4rem);">{t.prewedding.celebracion}</h2>
  <p class="font-['WeddingSerif'] tracking-[.2em] text-[#333]" style="font-size: clamp(1rem, 4vw, 1.3rem);">{t.prewedding.celebracion_fecha}</p>
</div>

<script>
  const florIzq     = document.getElementById('flor-izq');
  const florDer     = document.getElementById('flor-der');
  const floralDiv   = document.getElementById('floral-divider');
  const anillo      = document.getElementById('anillo');

  // --- Utilidad: progreso de un elemento en viewport (0 = fuera abajo, 1 = fuera arriba)
  function getProgress(el: HTMLElement) {
    const rect = el.getBoundingClientRect();
    const vh = window.innerHeight;
    return (vh - rect.top) / (vh + rect.height);
  }

  // --- Fade + slide-up al entrar en viewport
  function initReveal(el: HTMLElement | null) {
    if (!el) return;
    el.style.opacity = '0';
    el.style.transform = 'translateY(30px)';
    el.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
  }

  function updateReveal(el: HTMLElement | null) {
    if (!el) return;
    const p = getProgress(el);
    if (p > 0.15) {
      el.style.opacity = '1';
      el.style.transform = 'translateY(0px)';
    }
  }

  initReveal(floralDiv);
  initReveal(anillo);

  // --- Scroll handler para parallax flores + reveal
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const section = document.getElementById('eventos');
        if (section) {
          const scrollY = window.scrollY;
          const sectionTop = section.getBoundingClientRect().top + scrollY;
          const progress = (scrollY - sectionTop + window.innerHeight) / (section.offsetHeight + window.innerHeight);
          const clamped = Math.max(0, Math.min(1, progress));

          const moveIzq = (clamped - 0.5) * -120;
          const moveDer = (clamped - 0.5) * -80;
          const opacity = clamped < 0.1 ? clamped * 10 : clamped > 0.9 ? (1 - clamped) * 10 : 1;

          if (florIzq) {
            florIzq.style.opacity = String(opacity);
            florIzq.dataset.parallax = String(moveIzq);
          }
          if (florDer) {
            florDer.style.opacity = String(opacity);
            florDer.dataset.parallax = String(moveDer);
          }
        }

        updateReveal(floralDiv);
        updateReveal(anillo);

        ticking = false;
      });
      ticking = true;
    }
  });

  // Trigger inicial por si ya están en viewport
  window.dispatchEvent(new Event('scroll'));

  // --- Balanceo suave continuo (brisa)
  let time = 0;
  function sway() {
    time += 0.015;
    const swing    = Math.sin(time) * 2.5;
    const swingDer = Math.sin(time + 1) * 2;
    const swingDiv = Math.sin(time + 0.5) * 0.8;
    const swingAni = Math.sin(time + 2) * 1.2;

    const parallaxIzq = parseFloat(florIzq?.dataset.parallax || '0');
    const parallaxDer = parseFloat(florDer?.dataset.parallax || '0');

    if (florIzq) florIzq.style.transform = `translateY(${parallaxIzq}px) rotate(${swing}deg)`;
    if (florDer) florDer.style.transform  = `translateY(${parallaxDer}px) rotate(${-swingDer}deg)`;
    if (floralDiv) floralDiv.style.rotate = `${swingDiv}deg`;
    if (anillo)    anillo.style.rotate    = `${swingAni}deg`;

    requestAnimationFrame(sway);
  }
  sway();
</script>