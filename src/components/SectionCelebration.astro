---
// src/components/SectionCelebration.astro
import { Image } from "astro:assets";
import celebrationLine from "../assets/images/line.png";
import celebration from "../assets/images/celebration.png";
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full max-w-[1000px] mx-auto flex flex-col items-center text-center px-4 mt-6 mb-16">
  <div class="relative w-full max-w-[480px] mx-auto" id="celebration-container">

    <!-- Base: ilustraciones sin línea -->
    <img src={celebration.src} alt="" class="w-full h-auto relative z-30" />

    <!-- Línea que se revela con scroll -->
    <div id="line-wrapper" class="absolute inset-0 z-20" style="clip-path: inset(0 0 100% 0);">
      <img src={celebrationLine.src} alt="" class="w-[80%] h-auto" />
    </div>

    <!-- Textos -->
    <div class="absolute z-30 font-['WeddingSerif'] text-left" style="top: 6%; left: 52%; width: 44%;">
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento1_hora}</p>
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento1_desc}</p>
      <p class="text-[#1a1a1a] font-bold underline leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento1_lugar}</p>
    </div>
    <div class="absolute z-30 font-['WeddingSerif'] text-right" style="top: 26%; left: -6%; width: 44%;">
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento2_hora}</p>
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento2_desc}</p>
      <p class="text-[#1a1a1a] font-bold leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento2_lugar}</p>
    </div>
    <div class="absolute z-30 font-['WeddingSerif'] text-left" style="top: 48%; left: 52%; width: 44%;">
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento3_hora}</p>
      <p class="text-[#333]" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento3_desc}</p>
      <p class="text-[#1a1a1a] font-bold underline leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento3_lugar}</p>
    </div>
    <div class="absolute z-30 font-['WeddingSerif'] text-right" style="top: 67%; left: -5%; width: 44%;">
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento4_hora}</p>
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento4_desc}</p>
    </div>
    <div class="absolute z-30 font-['WeddingSerif'] text-left" style="top: 88%; left: 54%; width: 44%;">
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento5_hora}</p>
      <p class="text-[#333] leading-snug" style="font-size: clamp(0.75rem, 2.8vw, 1rem);">{t.celebracion.evento5_desc}</p>
    </div>

  </div>
</div>

<script>
  const lineWrapper = document.getElementById('line-wrapper');
  const container   = document.getElementById('celebration-container');

  let ticking = false;

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        if (!container || !lineWrapper) return;

        const rect     = container.getBoundingClientRect();
        const vh       = window.innerHeight;
        const total    = rect.height + vh;
        const traveled = vh - rect.top;
        const progress = Math.max(0, Math.min(1, traveled / total));

        const revealPct = Math.round(progress * 100);
        lineWrapper.style.clipPath = `inset(0 0 ${100 - revealPct}% 0)`;

        ticking = false;
      });
      ticking = true;
    }
  });

  window.dispatchEvent(new Event('scroll'));
</script>