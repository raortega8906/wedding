---
// src/components/SectionDressCode.astro
import { Image } from "astro:assets";
import pareja from "../assets/images/pareja.png";
import ramaArriba from "../assets/images/rama-arriba.png";
import ramaAbajo from "../assets/images/rama-abajo.png";
import florDown from "../assets/images/flor-down.png";
import FondoAmarillo from "../assets/images/fondo-amarillo.png";
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full max-w-[1000px] mx-auto flex flex-col items-center text-center px-4 pt-26 mb-0 relative">
  <!-- Imagen de fondo fondo-amarillo.png -->
  <div
    class="absolute inset-0 z-0 pointer-events-none bg-no-repeat mx-auto md:bg-[length:1000px_auto] bg-[length:100%_auto] md:bg-[center_102%] bg-[center_108%]"
    style={`background-image: url('${FondoAmarillo.src}');`}
    aria-hidden="true"
  ></div>

  <h2 class="font-['WeddingSerif'] font-bold tracking-[.3em] uppercase text-[#1a1a1a] mb-8" style="font-size: clamp(1rem, 4vw, 1.4rem);">
    {t.dresscode.titulo}
  </h2>

  <div class="flex items-start justify-center w-full max-w-[480px] mx-auto mb-0 gap-2">
    <div class="flex flex-col items-center text-center font-['WeddingSerif'] pt-16 flex-1">
      <p class="text-[#1a1a1a] mb-1" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.dresscode.mujer}</p>
      <hr class="w-18 border-t-1 border-[#999] my-1" />
      <p class="text-[#444] leading-snug" style="font-size: clamp(0.75rem, 2.6vw, 0.95rem);">{t.dresscode.mujer_desc}</p>
    </div>

    <div class="flex-shrink-0 w-[45%] max-w-[180px]">
      <Image src={pareja} alt="Pareja dress code" class="reveal-heading w-full h-auto" widths={[200, 400]} />
    </div>

    <div class="flex flex-col items-center text-center font-['WeddingSerif'] pt-16 flex-1">
      <p class="text-[#1a1a1a] mb-1" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.dresscode.hombre}</p>
      <hr class="w-18 border-t-1 border-[#999] my-1" />
      <p class="text-[#444] leading-snug" style="font-size: clamp(0.75rem, 2.6vw, 0.95rem);">{t.dresscode.hombre_desc}</p>
    </div>
  </div>

  <div class="mb-10">
    <a href="#" class="inline-block px-8 py-1 border border-[#999] rounded-full font-['WeddingSerif'] tracking-widest text-[#666] hover:bg-[#000] hover:text-white transition-colors" style="font-size: clamp(0.7rem, 2.5vw, 0.85rem);">
      {t.dresscode.ver_referencia}
    </a>
  </div>

  <p class="font-['WeddingSerif'] font-bold text-[#1a1a1a] mb-2" style="font-size: clamp(0.9rem, 3.5vw, 1.15rem);">{t.dresscode.tonalidades_titulo}</p>
  <p class="font-['WeddingSerif'] text-[#444] mb-8" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.dresscode.tonalidades_valor}</p>

  <div class="w-full max-w-[300px] mx-auto mb-6">
    <Image src={ramaArriba} alt="" class="reveal-heading w-full h-auto" widths={[280, 560]} />
  </div>

  <p class="font-['WeddingSerif'] text-[#1a1a1a] mb-6" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.dresscode.adultos}</p>

  <div class="w-full max-w-[300px] mx-auto mb-0">
    <Image src={ramaAbajo} alt="" class="reveal-heading w-full h-auto" widths={[280, 560]} />
  </div>

  <div class="w-full max-w-[380px] mx-auto mt-[-2%]">
    <Image id="floral-down" src={florDown} alt="" class="w-full h-auto" widths={[340, 680]} />
  </div>
</div>