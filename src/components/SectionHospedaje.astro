---
// src/components/SectionHospedaje.astro
import { Image } from "astro:assets";
import ramaAbajo from "../assets/images/rama-arriba.png";
import hotelOsh from "../assets/images/hotel-osh.png";
import gallery1 from "../assets/images/hospedaje-1.png";
import gallery2 from "../assets/images/hospedaje-2.png";
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full max-w-[1000px] mx-auto flex flex-col items-center text-center px-4 mt-6 mb-12" id="hospedaje">

  <!-- Título Hospedaje -->
  <h2
    class="reveal-heading font-['Amoresa'] text-[#1a1a1a] mb-6"
    style="font-size: clamp(2.4rem, 10vw, 4rem);"
  >
    {t.hospedaje.titulo}
  </h2>

  <!-- Hotel principal -->
  <div class="flex-shrink-0 w-[100%] md:max-w-[400px] max-w-[300px]">
    <Image
      src={hotelOsh}
      alt="Hotel OSH"
      class="w-full h-auto"
      widths={[200, 400]}
    />
  </div>

  <!-- Nombre hotel -->
  <p
    class="font-['WeddingSerif'] text-[#1a1a1a] tracking-[.2em] mt-4 mb-1"
    style="font-size: clamp(0.9rem, 3.5vw, 1.15rem);"
  >
    {t.hospedaje.hotel_nombre}
  </p>
  <p
    class="font-['WeddingSerif'] text-[#444] mb-3"
    style="font-size: clamp(0.85rem, 3vw, 1.05rem);"
  >
    {t.hospedaje.hotel_desc}
  </p>

  <!-- Botón link descuento -->
  <div class="mb-12">
    <a
      href="#"
      class="inline-block px-8 py-1 border border-[#999] rounded-full font-['WeddingSerif'] tracking-widest text-[#666] hover:bg-[#000] hover:text-white transition-colors"
      style="font-size: clamp(0.7rem, 2.5vw, 0.85rem);"
    >
      {t.hospedaje.hotel_boton}
    </a>
  </div>

  <!-- Título sugerencias -->
  <p
    class="font-['WeddingSerif'] font-bold tracking-[.2em] uppercase text-[#1a1a1a] mb-6"
    style="font-size: clamp(0.85rem, 3vw, 1.05rem);"
  >
    {t.hospedaje.sugerencias}
  </p>

</div>

<!-- Galería full width fuera del contenedor centrado -->
<section class="w-full max-w-[1000px] mx-auto overflow-hidden mb-8">
  <div
    id="hotel-slider"
    class="flex gap-3 px-6 overflow-x-auto scroll-smooth no-scrollbar items-center select-none"
    style="cursor: grab;"
  >
    <div class="flex-shrink-0 w-[42vw] md:w-[220px] aspect-[3/4]">
      <img src={gallery1.src} class="w-full h-full object-cover rounded-[20px] shadow-lg pointer-events-none" alt="" />
    </div>
    <div class="flex-shrink-0 w-[42vw] md:w-[220px] aspect-[3/4]">
      <img src={gallery2.src} class="w-full h-full object-cover rounded-[20px] shadow-lg pointer-events-none" alt="" />
    </div>
    <div class="flex-shrink-0 w-[42vw] md:w-[220px] aspect-[3/4]">
      <img src={gallery1.src} class="w-full h-full object-cover rounded-[20px] shadow-lg pointer-events-none" alt="" />
    </div>
    <div class="flex-shrink-0 w-[42vw] md:w-[220px] aspect-[3/4]">
      <img src={gallery2.src} class="w-full h-full object-cover rounded-[20px] shadow-lg pointer-events-none" alt="" />
    </div>
    <div class="flex-shrink-0 w-[42vw] md:w-[220px] aspect-[3/4]">
      <img src={gallery1.src} class="w-full h-full object-cover rounded-[20px] shadow-lg pointer-events-none" alt="" />
    </div>
    <div class="flex-shrink-0 w-[42vw] md:w-[220px] aspect-[3/4]">
      <img src={gallery2.src} class="w-full h-full object-cover rounded-[20px] shadow-lg pointer-events-none" alt="" />
    </div>
    <div class="flex-shrink-0 w-6 h-10"></div>
  </div>
</section>

<!-- Rama decorativa -->
<div class="w-full max-w-[300px] mx-auto mt-2 mb-12 px-4">
  <Image src={ramaAbajo} alt="" class="w-full h-auto" widths={[280, 560]} />
</div>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  #hotel-slider { overscroll-behavior-x: contain; }
</style>

<script>
  const hotelSlider = document.getElementById('hotel-slider');
  let isDown = false;
  let startX: number;
  let scrollLeft: number;

  if (hotelSlider) {
    hotelSlider.addEventListener('mousedown', (e) => {
      isDown = true;
      hotelSlider.style.cursor = 'grabbing';
      startX = (e as MouseEvent).pageX - hotelSlider.offsetLeft;
      scrollLeft = hotelSlider.scrollLeft;
    });
    hotelSlider.addEventListener('mouseleave', () => {
      isDown = false;
      hotelSlider.style.cursor = 'grab';
    });
    hotelSlider.addEventListener('mouseup', () => {
      isDown = false;
      hotelSlider.style.cursor = 'grab';
    });
    hotelSlider.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = (e as MouseEvent).pageX - hotelSlider.offsetLeft;
      hotelSlider.scrollLeft = scrollLeft - (x - startX) * 2;
    });
  }
</script>