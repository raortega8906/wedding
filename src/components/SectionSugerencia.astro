---
import { Image } from "astro:assets";
import caja from "../assets/images/caja.png";
import percha from "../assets/images/percha.png";
import { useTranslations, type Lang } from '../i18n/index.ts';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<div class="w-full max-w-[600px] mx-auto flex flex-col px-4 mt-6 mb-12">

  <div class="flex items-center gap-4 mb-12">
    <div class="flex-shrink-0 w-[38%] max-w-[160px]">
      <Image src={caja} alt="Make up" class="w-full h-auto" widths={[160, 320]} />
    </div>
    <div class="flex-1 flex flex-col items-end pr-4">
      <div class="flex flex-col items-center text-center">
        <p class="font-['WeddingSerif'] font-bold tracking-[.2em] uppercase text-[#1a1a1a] mb-2" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.sugerencia.makeup_titulo}</p>
        <p class="font-['WeddingSerif'] text-[#444] mb-2" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.sugerencia.makeup_1}</p>
        <div class="mb-4">
          <a href="#" class="inline-block px-6 py-1.5 border border-[#999] rounded-full font-['WeddingSerif'] tracking-widest text-[#666] hover:bg-[#f5f5f5] transition-colors" style="font-size: clamp(0.65rem, 2.2vw, 0.8rem);">{t.sugerencia.contactar}</a>
        </div>
        <p class="font-['WeddingSerif'] text-[#444] mb-2" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.sugerencia.makeup_2}</p>
        <div>
          <a href="#" class="inline-block px-6 py-1.5 border border-[#999] rounded-full font-['WeddingSerif'] tracking-widest text-[#666] hover:bg-[#f5f5f5] transition-colors" style="font-size: clamp(0.65rem, 2.2vw, 0.8rem);">{t.sugerencia.contactar}</a>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <div class="flex-1 flex flex-col items-start pl-4">
      <div class="flex flex-col items-center text-center">
        <p class="font-['WeddingSerif'] font-bold tracking-[.2em] uppercase text-[#1a1a1a] mb-2" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.sugerencia.traje_titulo}</p>
        <p class="font-['WeddingSerif'] text-[#444] mb-2" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.sugerencia.traje_1}</p>
        <div class="mb-4">
          <a href="#" class="inline-block px-6 py-1.5 border border-[#999] rounded-full font-['WeddingSerif'] tracking-widest text-[#666] hover:bg-[#f5f5f5] transition-colors" style="font-size: clamp(0.65rem, 2.2vw, 0.8rem);">{t.sugerencia.contactar}</a>
        </div>
        <p class="font-['WeddingSerif'] text-[#444] mb-2" style="font-size: clamp(0.85rem, 3vw, 1.05rem);">{t.sugerencia.traje_2}</p>
        <div>
          <a href="#" class="inline-block px-6 py-1.5 border border-[#999] rounded-full font-['WeddingSerif'] tracking-widest text-[#666] hover:bg-[#f5f5f5] transition-colors" style="font-size: clamp(0.65rem, 2.2vw, 0.8rem);">{t.sugerencia.contactar}</a>
        </div>
      </div>
    </div>
    <div class="flex-shrink-0 w-[38%] max-w-[160px]">
      <Image src={percha} alt="Alquiler de traje" class="w-full h-auto" widths={[160, 320]} />
    </div>
  </div>

</div>